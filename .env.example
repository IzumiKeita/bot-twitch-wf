# ==========================================
# CONFIGURACIÓN DEL BOT DE WARFRAME
# ==========================================

# 1. MÉTODO AUTOMÁTICO (RECOMENDADO)
# ------------------------------------------
# Para usar el generador de token integrado (Opción 2 en el menú start_bot.bat):
# 1. Crea una App en https://dev.twitch.tv/console
# 2. Pega aquí el Client ID y Client Secret
# 3. Ejecuta start_bot.bat y elige la opción 2
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI=http://localhost:3000

# 2. MÉTODO MANUAL (ALTERNATIVO)
# ------------------------------------------
# Si prefieres generar el token manualmente en https://twitchtokengenerator.com/
# (Scopes necesarios: chat:read chat:edit)
# Pégalo aquí (debe empezar por "oauth:").
# NOTA: Si usas el método automático, esto se rellenará solo.
TWITCH_TOKEN=

# 3. DATOS DEL CANAL (OBLIGATORIO)
# ------------------------------------------
# Tu nombre de usuario en Twitch (todo en minúsculas)
# Si usas el método automático, esto intentará rellenarse solo.
TWITCH_USERNAME=

# El canal donde el bot funcionará (generalmente el mismo que tu usuario)
TARGET_CHANNEL=

# 4. CONFIGURACIÓN ADICIONAL
# ------------------------------------------
# Modo Silencioso: Si es true, el bot lee pero no responde. (true/false)
SILENT_MODE=false
