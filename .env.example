# ==========================================
# CONFIGURACIÓN DEL BOT DE WARFRAME
# ==========================================

# 1. CREDENCIALES DE TWITCH (OBLIGATORIO)
# ------------------------------------------
# El token debe empezar por "oauth:". Puedes obtenerlo de:
# - Opción A (Fácil): https://twitchapps.com/tmi/
# - Opción B (Avanzada): Usando la herramienta 'Generador de Token' del menú (requiere paso 2)
TWITCH_TOKEN=oauth:pega_tu_token_aqui

# Tu nombre de usuario en Twitch (todo en minúsculas)
TWITCH_USERNAME=tu_usuario_aqui

# El canal donde el bot funcionará (generalmente el mismo que tu usuario)
TARGET_CHANNEL=tu_canal_aqui

# 2. CONFIGURACIÓN DE DESARROLLADOR (OPCIONAL / AVANZADO)
# ------------------------------------------
# Solo necesario si usas la herramienta de autocompletado de token (Opción 2 del menú)
# Consíguelos en: https://dev.twitch.tv/console
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI=http://localhost:3000

# 3. CONFIGURACIÓN DEL COMPORTAMIENTO
# ------------------------------------------
# Modo Silencioso: Si es true, el bot lee pero no responde. (true/false)
SILENT_MODE=false

# 4. INTELIGENCIA ARTIFICIAL (OPCIONAL)
# ------------------------------------------
# Por defecto usa 'local' (LM Studio). Cambia a 'groq', 'openai', etc. si tienes claves.
LLM_PROVIDER=local
LLM_API_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL_NAME=local-model
